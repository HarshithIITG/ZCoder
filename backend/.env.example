# backend/.env.example
# Copy this file to .env and fill in your values

# Server port (optional, defaults to 5000)
PORT=5000

# MongoDB connection string
# Local:   mongodb://localhost:27017/zcoder
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/zcoder
MONGODB_URI=mongodb://localhost:27017/zcoder

# JWT signing secret — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Groq AI API key — get one free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Allowed frontend origin (your Vercel URL in production, localhost in dev)
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
